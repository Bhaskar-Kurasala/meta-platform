{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/maintenance-action.schema.json",
  "title": "MaintenanceAction",
  "description": "A maintenance action requested based on anomaly detection or predictive analytics. Tracks the full lifecycle from request through completion.",
  "type": "object",
  "required": [
    "schema_version",
    "action_id",
    "asset_id",
    "requested_by",
    "priority",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "example": "1.0"
    },
    "action_id": {
      "type": "string",
      "format": "uuid"
    },
    "asset_id": {
      "type": "string",
      "format": "uuid",
      "description": "The asset requiring maintenance"
    },
    "triggered_by": {
      "type": ["object", "null"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["anomaly", "prediction", "manual", "scheduled"]
        },
        "source_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the anomaly or prediction that triggered this action"
        }
      },
      "description": "What triggered this maintenance action — provides data lineage"
    },
    "requested_by": {
      "type": "string",
      "format": "uuid",
      "description": "User who requested this action (or 'system' for auto-generated)"
    },
    "assigned_to": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Maintenance manager or technician assigned"
    },
    "title": {
      "type": "string",
      "maxLength": 255
    },
    "description": {
      "type": "string",
      "maxLength": 5000,
      "description": "Detailed description of required maintenance work"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": [
        "requested",
        "approved",
        "scheduled",
        "in_progress",
        "completed",
        "cancelled",
        "rejected"
      ]
    },
    "approved_by": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Manager who approved this action"
    },
    "approved_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "scheduled_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When maintenance is scheduled to occur"
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "cost_estimate": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Estimated cost in USD"
    },
    "actual_cost": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Actual cost after completion"
    },
    "notes": {
      "type": ["string", "null"],
      "maxLength": 5000,
      "description": "Technician notes or completion remarks"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
